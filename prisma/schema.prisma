generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CAIXA
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  role      Role      @default(CAIXA)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([username])
}

model CashFlow {
  id            Int       @id @default(autoincrement())
  date          DateTime
  saldoInicial  Float     @default(0)
  entradas      Float     @default(0)
  saidas        Float     @default(0)
  fechamento    Float
  diferenca     Float?
  observacao    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([date])
}

model Venda {
  id         Int      @id @default(autoincrement())
  date       DateTime
  avista     Float    @default(0)
  debito     Float    @default(0)
  credito    Float    @default(0)
  pix        Float    @default(0)
  ifood      Float    @default(0)
  outros     Float    @default(0)
  taxas      Float    @default(0)
  pizzas     Int      @default(0)
  observacao String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
}

model Funcionario {
  id        Int      @id @default(autoincrement())
  date      DateTime
  nome      String
  semana    String?
  valor     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model ContaFixa {
  id        Int      @id @default(autoincrement())
  date      DateTime
  despesa   String
  valor     Float
  pago      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model Insumo {
  id         Int      @id @default(autoincrement())
  date       DateTime
  fornecedor String
  valor      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
}
